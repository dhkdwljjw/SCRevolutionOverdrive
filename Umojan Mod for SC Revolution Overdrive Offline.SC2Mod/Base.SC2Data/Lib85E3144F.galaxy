//--------------------------------------------------------------------------------------------------
// Trigger: UmojanInit
//--------------------------------------------------------------------------------------------------
bool lib85E3144F_gt_UmojanInit_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    playergroup auto4B61DA2F_g;
    int auto4B61DA2F_var;

    // Actions
    if (!runActions) {
        return true;
    }

    if (((UnitTypeGetProperty("SCV", c_unitPropSuppliesUsed) == 0.0) && (UnitTypeGetProperty("Probe", c_unitPropSuppliesUsed) == 0.0) && (UnitTypeGetProperty("Drone", c_unitPropSuppliesUsed) == 0.0) && (UnitTypeGetProperty("DroneBurrowed", c_unitPropSuppliesUsed) == 0.0))) {
        auto4B61DA2F_g = PlayerGroupActive();
        auto4B61DA2F_var = -1;
        while (true) {
            auto4B61DA2F_var = PlayerGroupNextPlayer(auto4B61DA2F_g, auto4B61DA2F_var);
            if (auto4B61DA2F_var < 0) { break; }
            CatalogFieldValueSet(c_gameCatalogUnit, "Pioneer", "Food", auto4B61DA2F_var, "0");
        }
    }

    if (((CatalogFieldValueGetAsInt(c_gameCatalogAbil, "SCVHarvest", "FlagArray[" + IntToString(0) + "]", c_playerAny) == 1) && (CatalogFieldValueGetAsInt(c_gameCatalogAbil, "ProbeHarvest", "FlagArray[" + IntToString(0) + "]", c_playerAny) == 1) && (CatalogFieldValueGetAsInt(c_gameCatalogAbil, "DroneHarvest", "FlagArray[" + IntToString(0) + "]", c_playerAny) == 1))) {
        TriggerEnable(lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger, true);
        lib85E3144F_gf_UmojanInfiniteMoneyMapAction(UnitGroup("Pioneer", c_playerAny, RegionEntireMap(), UnitFilter((1 << c_targetFilterWorker), 0, (1 << c_targetFilterMissile), (1 << (c_targetFilterDead - 32))), 0));
    }
    else {
        TriggerEnable(lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger, false);
    }
    return true;
}

