// Trigger: UmojanInfiniteMoneyMap:Trigger
//--------------------------------------------------------------------------------------------------
bool lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    // Conditions
    if (testConds) {
        if (!(((UnitGetType(EventUnit()) == "Pioneer")))) {
            return false;
        }
    }

    // Actions
    if (!runActions) {
        return true;
    }

    lib85E3144F_gf_UmojanInfiniteMoneyMapAction(libNtve_gf_ConvertUnitToUnitGroup(EventUnit()));
    return true;
}

//--------------------------------------------------------------------------------------------------
void lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger_Init () {
    lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger = TriggerCreate("lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger_Func");
    TriggerEnable(lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger, false);
    TriggerAddEventUnitRegion(lib85E3144F_gt_UmojanInfiniteMoneyMapTrigger, null, RegionEntireMap(), true);
}

