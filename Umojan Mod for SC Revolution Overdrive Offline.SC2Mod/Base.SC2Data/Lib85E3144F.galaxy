void lib85E3144F_gf_UmojanInfiniteMoneyMapNewOrder (unit lp_unit, abilcmd lp_oldAbil, abilcmd lp_newAbil) {
    // Variable Declarations
    int lv_i;
    int lv_count;
    order[4] lv_orders;
    order lv_currOrder;

    // Automatic Variable Declarations
    const int autoA8A5D88A_ae = 3;
    const int autoA8A5D88A_ai = 1;
    int autoED22DEF8_ae;
    const int autoED22DEF8_ai = 1;

    // Variable Initialization
    lv_count = -1;

    // Implementation
    lv_i = 0;
    for ( ; ( (autoA8A5D88A_ai >= 0 && lv_i <= autoA8A5D88A_ae) || (autoA8A5D88A_ai < 0 && lv_i >= autoA8A5D88A_ae) ) ; lv_i += autoA8A5D88A_ai ) {
        lv_currOrder = UnitOrder(lp_unit, lv_i);
        if ((lv_currOrder != null)) {
            if ((OrderGetAbilityCommand(lv_currOrder) == lp_oldAbil)) {
                lv_orders[lv_i] = OrderTargetingUnit(lp_newAbil, OrderGetTargetUnit(lv_currOrder));
            }
            else {
                lv_orders[lv_i] = UnitOrder(lp_unit, lv_i);
            }
            lv_count = lv_i;
        }
        else {
            break;
        }
    }
    UnitAbilityAdd(lp_unit, AbilityCommandGetAbility(lp_newAbil));
    UnitAbilityRemove(lp_unit, AbilityCommandGetAbility(lp_oldAbil));
    if ((lv_count == -1)) {
        return;
    }

    autoED22DEF8_ae = lv_count;
    lv_i = 0;
    for ( ; ( (autoED22DEF8_ai >= 0 && lv_i <= autoED22DEF8_ae) || (autoED22DEF8_ai < 0 && lv_i >= autoED22DEF8_ae) ) ; lv_i += autoED22DEF8_ai ) {
        if ((lv_i == 0)) {
            UnitIssueOrder(lp_unit, lv_orders[lv_i], c_orderQueueReplace);
        }
        else {
            UnitIssueOrder(lp_unit, lv_orders[lv_i], c_orderQueueAddToEnd);
        }
    }
}

