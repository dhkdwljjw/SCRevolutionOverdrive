// Trigger: Nano Cleanse
//--------------------------------------------------------------------------------------------------
bool lib85E3144F_gt_NanoCleanse_Func (bool testConds, bool runActions) {
    // Variable Declarations
    fixed lv_inheritedDamage;
    fixed lv_reducedDamage;
    fixed lv_nanoCleanseTargetShield;
    unit lv_nanoCleanseTarget;

    // Automatic Variable Declarations
    string auto7330E48B_val;

    // Variable Initialization

    // Actions
    if (!runActions) {
        return true;
    }

    lv_nanoCleanseTarget = EventUnit();
    lv_inheritedDamage = UnitBehaviorEffectTreeUserData(UnitBehaviorEffectUnit(lv_nanoCleanseTarget, EventUnitBehavior(), c_effectUnitTarget, 0), "NanoCleanseData", "InheritedDamageNanoCleanse");
    lv_nanoCleanseTargetShield = UnitBehaviorEffectTreeUserData(lv_nanoCleanseTarget, "NanoCleanseData", "NanoCleanseShield");
    lv_reducedDamage = MinF(lv_inheritedDamage, lv_nanoCleanseTargetShield);
    UnitBehaviorEffectTreeSetUserData(lv_nanoCleanseTarget, "NanoCleanseData", "NanoCleanseShield", (lv_nanoCleanseTargetShield - lv_reducedDamage));
    lv_inheritedDamage -= lv_reducedDamage;
    if (((lv_nanoCleanseTargetShield - lv_reducedDamage) <= 0.0)) {
        UnitBehaviorRemove(lv_nanoCleanseTarget, "NanoCleanse", 1);
    }

    if ((lv_inheritedDamage > 0.0)) {
        auto7330E48B_val = EventUnitBehavior();
        if (auto7330E48B_val == "NanoCleanseMelee") {
            if ((libNtve_gf_CatalogFieldValueGetAsReal(c_gameCatalogEffect, EventUnitDamageEffect(), "ArmorReduction", EventUnitDamageSourcePlayer()) == 1.0)) {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageMeleeArmorReducted", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
            else {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageMeleeArmorIgnored", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
        }
        else if (auto7330E48B_val == "NanoCleanseRanged") {
            if ((libNtve_gf_CatalogFieldValueGetAsReal(c_gameCatalogEffect, EventUnitDamageEffect(), "ArmorReduction", EventUnitDamageSourcePlayer()) == 1.0)) {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageRangedArmorReducted", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
            else {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageRangedArmorIgnored", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
        }
        else if (auto7330E48B_val == "NanoCleanseSplash") {
            if ((libNtve_gf_CatalogFieldValueGetAsReal(c_gameCatalogEffect, EventUnitDamageEffect(), "ArmorReduction", EventUnitDamageSourcePlayer()) == 1.0)) {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageSplashArmorReducted", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
            else {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageSplashArmorIgnored", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
        }
        else if (auto7330E48B_val == "NanoCleanseSpell") {
            if ((libNtve_gf_CatalogFieldValueGetAsReal(c_gameCatalogEffect, EventUnitDamageEffect(), "ArmorReduction", EventUnitDamageSourcePlayer()) == 1.0)) {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageSpellArmorReducted", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
            else {
                UnitDamage(EventUnitDamageSourceUnit(), "DamageSpellArmorIgnored", lv_nanoCleanseTarget, lv_inheritedDamage);
            }
        }
        else {
        }
    }

    return true;
}

